<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- DJI MSDK V5 required permissions (mirror the 5.18.0 sample manifest) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Foreground service: streaming GPS to the API while the controller is dimmed/backgrounded. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 9 (API 28) requires the special foreground-service permission. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Android 13+ runtime notification permission for the ongoing notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- DJI SDK requires USB access to talk to the controller's aircraft link. -->
    <uses-permission android:name="android.permission.USB_PERMISSION" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <!-- App Key is injected here from manifestPlaceholders["API_KEY"] = AIRCRAFT_API_KEY. -->
    <application
        android:name=".App"
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.DroneTopo"
        tools:targetApi="34">

        <meta-data
            android:name="com.dji.sdk.API_KEY"
            android:value="${API_KEY}" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.DroneTopo">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:parentActivityName=".ui.MainActivity" />

        <service
            android:name=".service.StreamingService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Streaming realtime aircraft GPS position to remote API for situational awareness during flight operations." />
        </service>
    </application>

</manifest>
